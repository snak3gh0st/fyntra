# Postgres (host btdb, via pgbouncer, rede privada Coolify)
DATABASE_URL="postgresql://lifeos_app:CHANGE_ME@10.0.0.2:6432/lifeos"

# Better Auth
BETTER_AUTH_SECRET="CHANGE_ME"
BETTER_AUTH_URL="http://localhost:3000"

# URL externa para solicitar ilustração no parceiro (ex.: API ou portal do cotador)
# Ex.: https://parceiro.example.com/illustrations
ILLUSTRATION_REQUEST_URL=

# Método de integração de ilustração com o parceiro: GET (padrão) ou POST
ILLUSTRATION_REQUEST_METHOD=

# Se usar POST, token de autenticação opcional para o endpoint
ILLUSTRATION_REQUEST_AUTH_TOKEN=
# Cabeçalho para o token (ex.: Authorization, X-API-KEY, X-Api-Key)
ILLUSTRATION_REQUEST_AUTH_HEADER=
# Defina como true se ILLUSTRATION_REQUEST_AUTH_TOKEN for Bearer
ILLUSTRATION_REQUEST_AUTH_BEARER=

# Timeout de chamada da API de ilustração (ms), usado apenas em POST
ILLUSTRATION_REQUEST_TIMEOUT_MS=
